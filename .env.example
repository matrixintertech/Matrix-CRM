# Database
# DATABASE_URL may use Neon pooled host for runtime connections.
# DIRECT_URL should use the non-pooler Neon host for migration safety.
# Leave PRISMA_USE_NEON_ADAPTER unset to allow automatic selection.
# Use true to force the Neon WebSocket driver or false to force the native Prisma driver.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER.neon.tech/DB?sslmode=require&channel_binding=disable&gssencmode=disable"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require&channel_binding=disable&gssencmode=disable"
PRISMA_USE_NEON_ADAPTER="auto"

# Auth.js
AUTH_SECRET="replace-with-strong-random-secret"
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
OTP_DEV_MODE="false"
OTP_DELIVERY_CHANNEL="email"
OTP_LENGTH="6"
OTP_EXPIRY_SECONDS="300"
OTP_MAX_ATTEMPTS="5"
OTP_RESEND_COOLDOWN_SECONDS="30"
OTP_SEND_RATE_LIMIT_WINDOW_SECONDS="900"
OTP_SEND_RATE_LIMIT_MAX="5"
OTP_VERIFY_RATE_LIMIT_WINDOW_SECONDS="900"
OTP_VERIFY_RATE_LIMIT_MAX="10"

# SMTP email delivery for OTP
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user@example.com"
SMTP_PASSWORD="replace-with-smtp-password"
SMTP_FROM="Matrix CRM <no-reply@example.com>"

# Shared OTP rate limiting
RATE_LIMIT_DRIVER="memory"
UPSTASH_REDIS_REST_URL="https://your-upstash-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-rest-token"
ALLOW_MEMORY_RATE_LIMIT_IN_PRODUCTION="false"

# Health diagnostics
HEALTH_SHOW_DETAILS="false"
ACTIVITY_LOG_RETENTION_DAYS="90"

# Bootstrap seed placeholders
BOOTSTRAP_ADMIN_EMAIL="admin@matrixcrm.local"
BOOTSTRAP_ADMIN_PHONE="+910000000000"
PLATFORM_SERVICE_PARTNER_CODE="PLATFORM"
PLATFORM_SERVICE_PARTNER_NAME="Platform Tenant"

# Development/test seed only
SEED_DEV_TEST_USERS="false"
DEV_TEST_USER_EMAIL="project.manager@matrixcrm.local"
DEV_TEST_USER_PHONE="+910000000001"
