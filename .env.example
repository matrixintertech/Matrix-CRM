
NODE_ENV="development"
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"
AUTH_SECRET="replace-with-strong-random-secret"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

OTP_DEV_MODE="true"
OTP_DELIVERY_CHANNEL="email"
OTP_LENGTH="6"
OTP_EXPIRY_SECONDS="300"
OTP_MAX_ATTEMPTS="5"
OTP_RESEND_COOLDOWN_SECONDS="30"
OTP_SEND_RATE_LIMIT_WINDOW_SECONDS="900"
OTP_SEND_RATE_LIMIT_MAX="5"
OTP_VERIFY_RATE_LIMIT_WINDOW_SECONDS="900"
OTP_VERIFY_RATE_LIMIT_MAX="10"

SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="replace-with-smtp-user"
SMTP_PASSWORD="replace-with-smtp-password"
SMTP_FROM="Matrix CRM <no-reply@example.com>"

RATE_LIMIT_DRIVER="upstash"
CACHE_DRIVER="upstash"
CACHE_DEFAULT_TTL_SECONDS="60"
CACHE_DEBUG="false"
PERF_LOGGING="false"
PERFORMANCE_DIAGNOSTICS_ENABLED="false"
TASK_LOCATION_REQUIRED="false"
TASK_ATTACHMENT_MAX_MB="5"
STORAGE_DRIVER="local"
S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="replace-with-bucket-name"
S3_ACCESS_KEY_ID="replace-with-s3-access-key-id"
S3_SECRET_ACCESS_KEY="replace-with-s3-secret-access-key"
S3_PUBLIC_BASE_URL="https://cdn.example.com"
UPSTASH_REDIS_REST_URL="https://example.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-rest-token"
